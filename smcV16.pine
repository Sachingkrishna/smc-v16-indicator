    tooltip='ICT Silver Bullet windows — highest probability FVG entry times.\nAll times use the Kill Zone Timezone setting.')
kzTimezoneInput         = input.string('America/New_York', 'Kill Zone Timezone', group=KILLZONE_GROUP,
     options=['America/New_York','America/Chicago','America/Los_Angeles',
              'Europe/London','Europe/Berlin','Asia/Tokyo','Asia/Hong_Kong',
              'Asia/Kolkata','Asia/Singapore','Australia/Sydney','UTC'],
     tooltip='All kill zone times are defined in this timezone.\nDefault: America/New_York (EST/EDT)')

showSessionsInput       = input(false, 'Show Session Boxes',     group=SESSION_GROUP)
sessSydneyInput         = input(true,  'Sydney (17:00–02:00)',   group=SESSION_GROUP, inline='ss')
sessSydneyColorInput    = input.color(color.new(#4caf50, 85), '',group=SESSION_GROUP, inline='ss')
sessTokyoInput          = input(true,  'Tokyo (19:00–04:00)',    group=SESSION_GROUP, inline='st')
sessTokyoColorInput     = input.color(color.new(#ff5722, 85), '',group=SESSION_GROUP, inline='st')
sessLondonInput         = input(true,  'London (03:00–12:00)',   group=SESSION_GROUP, inline='sl')
