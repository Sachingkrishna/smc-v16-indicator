sessNYInput             = input(true,  'New York (08:00–17:00)', group=SESSION_GROUP, inline='sn')
sessNYColorInput        = input.color(color.new(#ff9800, 85), '',group=SESSION_GROUP, inline='sn')
sessTimezoneInput       = input.string('America/New_York', 'Session Timezone', group=SESSION_GROUP,
     options=['America/New_York','America/Chicago','America/Los_Angeles',
              'Europe/London','Europe/Berlin','Asia/Tokyo','Asia/Hong_Kong',
              'Asia/Kolkata','Asia/Singapore','Australia/Sydney','UTC'],
     tooltip='Session times defined in this timezone.')
sessBoxBorderInput      = input(true, 'Show Box Border',   group=SESSION_GROUP)
sessLabelInput          = input(true, 'Show Session Labels',group=SESSION_GROUP)

showPDLevelsInput   = input(false, 'Previous Day Levels',       group=PDHL_GROUP)
showPDHighInput     = input(true,  'PDH',                       group=PDHL_GROUP, inline='pdh')
pdHighColorInput    = input.color(color.new(#f44336, 20), '',   group=PDHL_GROUP, inline='pdh')
pdHighStyleInput    = input.string(SOLID, '',                   group=PDHL_GROUP, inline='pdh', options=[SOLID,DASHED,DOTTED])
showPDLowInput      = input(true,  'PDL',                       group=PDHL_GROUP, inline='pdl')
pdLowColorInput     = input.color(color.new(#4caf50, 20), '',   group=PDHL_GROUP, inline='pdl')
pdLowStyleInput     = input.string(SOLID, '',                   group=PDHL_GROUP, inline='pdl', options=[SOLID,DASHED,DOTTED])
showPDOpenInput     = input(true,  'PDO (Prev Day Open)',       group=PDHL_GROUP, inline='pdo')
pdOpenColorInput    = input.color(color.new(#ff9800, 20), '',   group=PDHL_GROUP, inline='pdo')
