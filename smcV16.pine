    tooltip='Open price at 00:00 in the Kill Zone timezone.\nICT treats this as a key daily magnet/pivot.\nOnly works on intraday timeframes where a bar opens at midnight.')

showNDOGInput      = input(false, 'Show NDOG (New Day Opening Gap)', group=NDOG_GROUP)
ndogColorInput     = input.color(color.new(#2196f3, 80), 'NDOG Color', group=NDOG_GROUP)
